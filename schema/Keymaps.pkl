/// Durian keymaps schema.
/// Usage: import "schema/Keymaps.pkl" as K
module schema.Keymaps

class KeymapGlobalSettings {
  keymaps_enabled: Boolean = true
  sequence_timeout: Float = 1.0
}

class KeymapEntry {
  action: String
  key: String
  modifiers: Listing<"cmd"|"ctrl"|"shift"|"alt"> = new {}
  enabled: Boolean = true
  sequence: Boolean = false
  supports_count: Boolean = false
  context: "list"|"search"|"tag_picker"|"thread"|"compose_normal" = "list"
  tags: String?
}
